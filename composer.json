{
    "name": "cobacoch/templategraph-php",
    "description": "Template include graph generator for PHP static sites",
    "type": "library",
    "license": ["MIT", "Apache-2.0"],
    "authors": [
        {
            "name": "Kota Kobayashi",
            "email": "kk@cobaco.ch"
        }
    ],
    "require": {
        "php": ">=8.4"
    },
    "autoload": {
        "psr-4": {
            "Cobacoch\\Templategraph\\": "php/"
        }
    },
    "archive": {
        "exclude": [
            "/.editorconfig",
            "/.github",
            "/.gitattributes",
            "/Cargo.lock",
            "/Cargo.toml",
            "/about.hbs",
            "/about.toml",
            "/deny.toml",
            "/fixtures",
            "/lefthook.yaml",
            "/src",
            "/target",
            "/tests",
            "/vendor"
        ]
    }
}
